# 공개 사이트 절대 URL (SEO: canonical, sitemap, robots, OG). 프로덕션에서 설정 권장.
# 예: https://air-miso.vercel.app
NEXT_PUBLIC_SITE_URL=

# Google Sheets Webhook URL
# Google Apps Script 웹앱 배포 후 받은 URL을 입력하세요
GOOGLE_SHEETS_WEBHOOK_URL=

# 예시:
# GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycby.../exec

# Slack Webhook URL (선택사항)
# Slack Incoming Webhook URL을 입력하세요
# 설정하지 않으면 Slack 알림이 전송되지 않습니다
SLACK_WEBHOOK_URL=

# 예시:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR_WORKSPACE/YOUR_CHANNEL/YOUR_TOKEN
